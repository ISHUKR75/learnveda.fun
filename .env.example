# ============================================================
# LearnVeda — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit actual secrets to version control.
# ============================================================

# -- Application --
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LearnVeda

# -- Clerk Authentication --
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -- MongoDB Database --
MONGODB_URI=mongodb://localhost:27017/learnveda
MONGODB_DB_NAME=learnveda

# -- Redis Cache --
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# -- Meilisearch --
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# -- AI Services --
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# -- Storage --
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# -- Payments --
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# -- Email --
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=noreply@learnveda.com

# -- Analytics --
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# -- Monitoring --
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# -- CDN --
NEXT_PUBLIC_CDN_URL=

# -- Socket.IO --
SOCKET_PORT=3001

# -- BullMQ --
BULL_REDIS_URL=redis://localhost:6379

# -- JWT (for service-to-service) --
JWT_SECRET=
JWT_EXPIRES_IN=7d
