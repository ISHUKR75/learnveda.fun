# =============================================================================
# docker/Dockerfile
# LearnVeda — Multi-stage Docker image for production deployment
#
# Build stages:
#  1. deps     — Install production dependencies only
#  2. builder  — Build the Next.js application
#  3. runner   — Minimal runtime image (alpine)
#
# Usage:
#  docker build -f docker/Dockerfile -t learnveda:latest .
#  docker run -p 3000:3000 --env-file .env.production learnveda:latest
#
# Size optimization:
#  - Uses Node.js alpine base (~5MB vs ~350MB for full image)
#  - Multi-stage build discards build tools from final image
#  - Standalone output from Next.js reduces image size further
#
# @see https://nextjs.org/docs/deployment#docker-image
# =============================================================================

# Stage 1: Install dependencies
# Uses node:20-alpine for minimal size
FROM node:20-alpine AS deps

# Install libc6-compat for compatibility with some native modules
RUN apk add --no-cache libc6-compat

# Set working directory
WORKDIR /app

# Copy only package files first (Docker layer caching)
# If package.json hasn't changed, npm ci will use cached node_modules
COPY apps/web/package.json apps/web/package-lock.json ./

# Install production + development dependencies for build
# Use --frozen-lockfile to ensure reproducible installs
RUN npm ci --frozen-lockfile

# =============================================================================
# Stage 2: Build the Next.js application
# Uses full node_modules from deps stage
# =============================================================================
FROM node:20-alpine AS builder

# Set working directory
WORKDIR /app

# Copy node_modules from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy application source code
COPY apps/web/ ./

# Set environment for production build
ENV NEXT_TELEMETRY_DISABLED=1  # Disable Next.js telemetry
ENV NODE_ENV=production        # Production mode

# Build the Next.js application
# --standalone creates a self-contained deployment folder
RUN npm run build

# =============================================================================
# Stage 3: Production runtime image
# Minimal image — only what's needed to run the app
# =============================================================================
FROM node:20-alpine AS runner

# Set working directory
WORKDIR /app

# Security: Create a non-root user for running the app
# Never run containers as root in production
RUN addgroup --system --gid 1001 nodejs      # Create nodejs group
RUN adduser  --system --uid  1001 nextjs     # Create nextjs user

# Copy only the built application (standalone mode)
# This is much smaller than copying all source + node_modules
COPY --from=builder /app/.next/standalone ./   # Standalone server
COPY --from=builder /app/.next/static ./.next/static # Static assets
COPY --from=builder /app/public ./public       # Public directory

# Set correct permissions for the nextjs user
RUN chown -R nextjs:nodejs /app

# Switch to non-root user for security
USER nextjs

# Expose the application port
EXPOSE 3000

# Set runtime environment
ENV PORT=3000             # Port the server listens on
ENV HOSTNAME="0.0.0.0"   # Bind to all interfaces
ENV NODE_ENV=production   # Production mode

# Health check — Docker will restart the container if this fails
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/api/health', (r) => process.exit(r.statusCode === 200 ? 0 : 1))" \
  || exit 1

# Start the Next.js server
# standalone/server.js is generated by Next.js standalone build
CMD ["node", "server.js"]
