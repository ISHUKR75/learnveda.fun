# =============================================================================
# LearnVeda — apps/web Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git
# =============================================================================

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get from: https://clerk.com/dashboard → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Clerk redirect URLs — where users go after sign-in/out
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Application URL ───────────────────────────────────────────────────────────
# In development: use http://localhost:3000
# In production: your actual domain (https://learnveda.in)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com/ → Your Cluster → Connect
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/learnveda?retryWrites=true&w=majority

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get from: https://upstash.com/ → Your Database → REST API
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── AI (OpenAI for AI Tutor) ──────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Email (Resend for transactional emails) ───────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@learnveda.in

# ── Cloudinary (Image & Video storage) ───────────────────────────────────────
# Get from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLOUDINARY_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Razorpay (Payments — Indian gateway) ──────────────────────────────────────
# Get from: https://dashboard.razorpay.com/ → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Analytics ─────────────────────────────────────────────────────────────────
# Optional — add your PostHog/Vercel Analytics key
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Development ───────────────────────────────────────────────────────────────
NODE_ENV=development
