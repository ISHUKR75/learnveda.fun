# =============================================================================
# apps/web/.env.example
# LearnVeda — Environment Variables Reference
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# Required variables are marked with [REQUIRED]
# Optional variables work in demo mode if left empty
# =============================================================================

# =============================================================================
# CLERK AUTHENTICATION [REQUIRED]
# Get these from: https://dashboard.clerk.com → Your App → API Keys
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here    # Frontend public key
CLERK_SECRET_KEY=sk_test_your_key_here                     # Backend secret key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here        # Svix webhook signing secret

# Clerk redirect URLs (keep these as-is for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in                     # Sign-in page URL
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up                     # Sign-up page URL
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard             # Redirect after sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard             # Redirect after sign-up

# =============================================================================
# MONGODB [REQUIRED]
# Get from: https://mongodb.com/atlas (free tier available)
# =============================================================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/learnveda?retryWrites=true&w=majority

# =============================================================================
# SESSION & SECURITY [REQUIRED]
# Generate with: openssl rand -base64 32
# =============================================================================
SESSION_SECRET=your-random-secret-at-least-32-characters-long

# =============================================================================
# APP URL
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:5000                   # Local dev URL
# NEXT_PUBLIC_APP_URL=https://learnveda.in                 # Production URL

# =============================================================================
# REDIS [OPTIONAL — uses in-memory fallback if not set]
# Get from: https://upstash.com (free tier) or redis.io
# =============================================================================
REDIS_URL=redis://localhost:6379                            # Local Redis
# REDIS_URL=rediss://username:password@host:6379            # Upstash Redis (production)

# =============================================================================
# OPENAI [OPTIONAL — AI Tutor feature]
# Get from: https://platform.openai.com/api-keys
# Demo mode: returns pre-written responses without calling OpenAI
# =============================================================================
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# =============================================================================
# RESEND EMAIL [OPTIONAL — transactional emails]
# Get from: https://resend.com (100 emails/day free)
# Demo mode: logs emails to console instead of sending
# =============================================================================
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=LearnVeda <hello@learnveda.in>            # Sender email

# =============================================================================
# STRIPE [OPTIONAL — international payments]
# Get from: https://dashboard.stripe.com/apikeys
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_public_key

# Stripe price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=price_monthly_id_here
STRIPE_PRICE_PRO_YEARLY=price_yearly_id_here
STRIPE_PRICE_SCHOOL_YEARLY=price_school_yearly_id_here

# =============================================================================
# RAZORPAY [OPTIONAL — Indian payments (UPI, NetBanking, Cards)]
# Get from: https://dashboard.razorpay.com/app/keys
# =============================================================================
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id

# Razorpay price IDs (in paisa — 1 INR = 100 paisa)
RAZORPAY_PLAN_PRO_MONTHLY_ID=plan_monthly_id_here
RAZORPAY_PLAN_PRO_YEARLY_ID=plan_yearly_id_here

# =============================================================================
# CLOUDINARY [OPTIONAL — media uploads: avatars, thumbnails]
# Get from: https://cloudinary.com/console
# =============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=learnveda                         # Create in Cloudinary Dashboard

# =============================================================================
# ONLINE COMPILER [OPTIONAL — /compiler feature]
# Option 1: Judge0 (via RapidAPI)
# Get from: https://rapidapi.com/judge0-official/api/judge0-ce
# =============================================================================
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Option 2: Piston (self-hosted — see https://github.com/engineer-man/piston)
PISTON_API_URL=https://emkc.org/api/v2/piston                # Public Piston API (rate limited)
# PISTON_API_URL=http://localhost:2000                       # Self-hosted Piston

# =============================================================================
# ANALYTICS [OPTIONAL]
# =============================================================================
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX               # Google Analytics 4 Measurement ID
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key               # PostHog analytics key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com            # PostHog host

# =============================================================================
# ADMIN ACCESS [OPTIONAL]
# Comma-separated list of Clerk user IDs with admin access
# =============================================================================
ADMIN_USER_IDS=user_abc123,user_def456                     # Admin Clerk user IDs

# =============================================================================
# SENTRY [OPTIONAL — error tracking in production]
# Get from: https://sentry.io
# =============================================================================
SENTRY_DSN=https://abc123@sentry.io/456789                 # Sentry DSN for error tracking
NEXT_PUBLIC_SENTRY_DSN=https://abc123@sentry.io/456789     # Sentry DSN for frontend
